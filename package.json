{
  "name": "request-buddy",
  "version": "1.0.0",
  "description": "Modern API Development & Testing Desktop App",
  "private": true,
  "workspaces": [
    "apps/*",
    "backend/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "preview": "npm run preview --workspace=apps/web",
    "electron:dev": "npm run electron:dev --workspace=apps/desktop",
    "electron:build": "npm run build --workspace=apps/web && npm run build --workspace=apps/desktop",
    "electron:preview": "npm run preview --workspace=apps/desktop",
    "release": "npm run build --workspace=apps/web && npm run release --workspace=apps/desktop",
    "release:mac": "./scripts/build-mac-release.sh",
    "backend:dev": "npm run start:dev --workspace=backend/api",
    "backend:build": "npm run build --workspace=backend/api",
    "backend:start": "npm run start:prod --workspace=backend/api",
    "dev:legacy": "vite",
    "build:legacy": "vite build",
    "electron:dev:legacy": "concurrently \"npm run dev:legacy\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build:legacy": "npm run build:legacy && electron-builder"
  },
  "homepage": "./",
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "date-fns": "^2.30.0",
    "firebase": "^10.5.0",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.7.1",
    "react-router-dom": "^6.17.0",
    "uuid": "^9.0.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^27.0.0",
    "electron-builder": "^24.6.4",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "vite": "^4.5.0",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
